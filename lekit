      if [ "$update_choice" != "n" ] && [ "$update_choice" != "N" ]; then
        install_theme
      fi
    else
      if [ "$is_startup" != "startup" ]; then
        echo "$(msg theme_update_latest) ($theme_installed_version)."
      fi
    fi
  else
    if [ "$is_startup" != "startup" ]; then
      echo "$(msg theme_update_github_err)"
    fi
  fi
}

