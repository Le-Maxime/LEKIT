# --- ИНИЦИАЛИЗАЦИЯ ЯЗЫКА ---
init_language() {
  if [ -f "$LANG_FILE" ]; then
    LEKIT_LANG=$(cat "$LANG_FILE")
  else
    echo "=================================================="
    echo "  Выберите язык / Choose language:"
    echo "  [1] Русский (RU)"
    echo "  [2] English (EN)"
    echo "=================================================="
    printf "Ваш выбор / Your choice [1]: "
    read -r lang_choice
    case "$lang_choice" in
      2) LEKIT_LANG="en" ;;
      *) LEKIT_LANG="ru" ;;
    esac
    if [ -w "/etc" ]; then
      echo "$LEKIT_LANG" > "$LANG_FILE" 2>/dev/null
    fi
  fi
}

init_language

