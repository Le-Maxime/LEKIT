# --- ФУНКЦИИ ДЛЯ LEBOOT ---
get_installed_leboot_version() {
  local mtd_fip=$(find_mtd_partition "fip")
  if [ -z "$mtd_fip" ]; then
    echo "$(msg status_not_installed)"
    return 1
  fi
  
  if [ ! -r "/dev/$mtd_fip" ]; then
    echo "$(msg status_unknown)"
    return 1
  fi

  local raw_ver=""
  if command -v strings >/dev/null; then
    raw_ver=$(strings "/dev/$mtd_fip" 2>/dev/null | grep -m 1 -E "U-Boot [0-9]{4}\.[0-9]{2}|LEBOOT")
  else
    raw_ver=$(dd if="/dev/$mtd_fip" bs=1k count=1024 2>/dev/null | tr -cd '\11\12\15\40-\176' | grep -o -m 1 -E "U-Boot [0-9]{4}\.[0-9]{2}[^ ]*|LEBOOT-[^ ]*")
  fi

  if echo "$raw_ver" | grep -q "LEBOOT"; then
    echo "$raw_ver" | grep -o -E "LEBOOT-v[0-9]+(\.[0-9]+)+" | head -n 1
  elif echo "$raw_ver" | grep -q "U-Boot"; then
    echo "$raw_ver" | grep -o -E "U-Boot [0-9]{4}\.[0-9]{2}(\.[0-9]+)*" | head -n 1
  else
    msg "status_unknown"
  fi
}

backup_fip() {
  local mtd_fip=$(find_mtd_partition "fip")
  local mtd_fip_name=$(find_mtd_partition_name "fip")
  if [ -n "$mtd_fip" ]; then
    echo -e "\n$(msg leboot_backup_start) $mtd_fip_name ($mtd_fip)..."
    if dd if="/dev/$mtd_fip" of="/tmp/fip-backup.bin" 2>/dev/null; then
      echo "$(msg leboot_backup_success)"
    else
      echo "$(msg leboot_backup_err)"
    fi
  else
    echo "$(msg leboot_fip_not_found)"
  fi
}

select_file() {
  local pattern="$1"
  local prompt="$2"
  local files=$(ls $pattern 2>/dev/null || true)
  
  if [ -z "$files" ]; then
    return 1
  fi
  
  local count=$(echo "$files" | wc -w)
  if [ "$count" -eq 1 ]; then
    echo "$files"
    return 0
  fi
  
  echo -e "\n[!] $prompt" >&2
  local i=1
  for f in $files; do
    echo "  [$i] $f" >&2
    i=$((i + 1))
  done
  
  printf "$(msg leboot_select_file) (1-$((i-1))): " >&2
  read choice < /dev/tty
  
  local selected=$(echo $files | cut -d' ' -f"$choice")
  if [ -z "$selected" ]; then
    echo "Error: Invalid choice!" >&2
    return 1
  fi
  echo "$selected"
}

flash_leboot() {
  # Проверяем наличие разделов MTD
  if [ ! -f /proc/mtd ]; then
    echo "Error: Not running on an OpenWrt router!" >&2
    return 1
  fi

  local mtd_fip=$(find_mtd_partition "fip")
  local mtd_fip_name=$(find_mtd_partition_name "fip")
  
  if [ -z "$mtd_fip" ] || [ -z "$mtd_fip_name" ]; then
    echo "$(msg leboot_fip_not_found)"
    return 1
  fi

  echo -e "\n$(msg leboot_fip_found) $mtd_fip_name ($mtd_fip)"

  # --- СНЯТИЕ ЗАЩИТЫ ОТ ЗАПИСИ ---
  echo "$(msg leboot_mtd_rw_install)"
  if command -v apk >/dev/null 2>&1; then
    apk update || true
    apk add kmod-mtd-rw || true
  elif command -v opkg >/dev/null 2>&1; then
    opkg update || true
    opkg install kmod-mtd-rw || true
  fi

  echo "$(msg leboot_mtd_rw_loading)"
  insmod mtd-rw i_want_a_brick=1 2>/dev/null || \
  insmod mtd_rw i_want_a_brick=1 2>/dev/null || \
  insmod "/lib/modules/$(uname -r)/mtd-rw.ko" i_want_a_brick=1 2>/dev/null || \
  insmod "/lib/modules/$(uname -r)/mtd_rw.ko" i_want_a_brick=1 2>/dev/null || \
  modprobe mtd-rw i_want_a_brick=1 2>/dev/null || \
  modprobe mtd_rw i_want_a_brick=1 2>/dev/null || true

  if lsmod | grep -qE "mtd_rw|mtd-rw"; then
    echo "$(msg leboot_mtd_rw_success)"
  else
    echo -e "\033[1;33m[!] $(msg leboot_mtd_rw_warn)\033[0m"
    if command -v apk >/dev/null 2>&1; then
      echo "  apk update && apk add kmod-mtd-rw && insmod mtd-rw i_want_a_brick=1"
    else
      echo "  opkg update && opkg install kmod-mtd-rw && insmod mtd-rw i_want_a_brick=1"
    fi
  fi

  local fip_file=""

  # Интерактивное скачивание с GitHub
  echo ""
  printf "$(msg leboot_dl_prompt) $(msg yes_no_default_n)"
  read dl_confirm < /dev/tty
  case "$dl_confirm" in
    y|Y|yes|YES)
      echo "$(msg leboot_dl_check)"
      
      local github_api="https://api.github.com/repos/Le-Maxime/LEBOOT/releases/latest"
      local json=""
      if command -v curl >/dev/null 2>&1; then
        json=$(curl -s -L "$github_api")
      else
        json=$(wget -qO- --no-check-certificate "$github_api" || true)
      fi
      
      if [ -z "$json" ] || echo "$json" | grep -q "message.*Not Found"; then
        echo "$(msg leboot_dl_err)"
        return 1
      fi
      
      local url=$(echo "$json" | grep -oE 'https://github.com/[^"]+' | grep -iE '\.fip$' | grep -i 'LEBOOT' | head -n 1)

      if [ -z "$url" ]; then
        url=$(echo "$json" | grep -oE 'https://github.com/[^"]+' | grep -E '\.(bin|fip)$' | grep -i 'cf-wr632ax' | head -n 1)
      fi

      if [ -z "$url" ]; then
        url=$(echo "$json" | grep -oE 'https://github.com/[^"]+' | grep -E '\.(bin|fip)$' | head -n 1)
      fi

      if [ -z "$url" ]; then
        echo "$(msg leboot_files_no_fip)"
        return 1
      fi
      
      local filename=$(basename "$url")
      echo "$(msg leboot_downloading) $filename..."
      
      fip_file="/tmp/leboot-flash.fip"
      if command -v curl >/dev/null 2>&1; then
        if ! curl -L -o "$fip_file" "$url"; then
          echo "Error: curl download failed!" >&2
          return 1
        fi
      else
        if ! wget -O "$fip_file" --no-check-certificate "$url"; then
          echo "Error: wget download failed!" >&2
          return 1
        fi
      fi
      echo "$filename $(msg leboot_download_ok)"
      ;;
    *)
      echo "$(msg leboot_local_files)"
      fip_file=$(select_file "LEBOOT-*.fip" "Найдены файлы LEBOOT FIP / Found LEBOOT FIP files:")
      if [ -z "$fip_file" ]; then
        fip_file=$(select_file "*.fip" "Найдены файлы .fip / Found .fip files:")
      fi
      if [ -z "$fip_file" ]; then
        fip_file=$(select_file "*fip*.bin" "Найдены файлы для FIP / Found files for FIP:")
      fi
      if [ -z "$fip_file" ]; then
        fip_file=$(select_file "*u-boot*.bin" "Найдены файлы U-Boot / Found U-Boot files:")
      fi
      ;;
  esac

  if [ -z "$fip_file" ] || [ ! -f "$fip_file" ]; then
    echo "Error: No firmware file found!" >&2
    return 1
  else
    echo "$(msg leboot_selected_fip) $fip_file"
  fi

  # Подтверждение от пользователя
  echo ""
  echo -e "\033[1;31m[!] $(msg leboot_brick_warn)\033[0m"
  echo -e "\033[1;33m[!] $(msg leboot_backup_recommend)\033[0m"
  printf "$(msg leboot_confirm_prompt) $(msg yes_no_default_n)"
  read confirm < /dev/tty
  case "$confirm" in
    y|Y|yes|YES)
      ;;
    *)
      echo "$(msg leboot_cancelled)"
      return 1
      ;;
  esac

  # Прошивка FIP
  echo "$(msg leboot_calc_md5)"
  md5sum "$fip_file"

  echo "$(msg leboot_writing) $mtd_fip_name..."
  if mtd write "$fip_file" "$mtd_fip_name"; then
    echo "=================================================="
    echo "   $(msg leboot_success)"
    echo "   $(msg leboot_finished)"
    echo "=================================================="
  else
    echo "Flashing failed!" >&2
    return 1
  fi
}

check_leboot_updates() {
  local is_startup="$1"
  if [ "$is_startup" != "startup" ]; then
    echo -e "\n--- $(msg leboot_update_title) ---"
  fi

  local mtd_fip=$(find_mtd_partition "fip")
  if [ -z "$mtd_fip" ]; then
    if [ "$is_startup" != "startup" ]; then
      echo "$(msg leboot_fip_not_found)"
    fi
    return 0
  fi

  if [ "$is_startup" != "startup" ]; then
    echo "$(msg leboot_dl_check)"
  fi

  local github_api="https://api.github.com/repos/Le-Maxime/LEBOOT/releases/latest"
  local json=""
  if command -v curl >/dev/null 2>&1; then
    json=$(curl -s -L "$github_api")
  else
    json=$(wget -qO- --no-check-certificate "$github_api" || true)
  fi

  local latest_version=$(echo "$json" | tr ',' '\n' | grep "^\"tag_name\":" | cut -d'"' -f4)

  if [ -n "$latest_version" ]; then
    local installed_version=$(get_installed_leboot_version)
    local clean_latest=$(echo "$latest_version" | sed 's/LEBOOT-//g' | sed 's/v//g' | cut -d'-' -f1 | cut -d'_' -f1 | sed 's/[^0-9.]//g')
    local clean_installed=$(echo "$installed_version" | sed 's/LEBOOT-//g' | sed 's/v//g' | cut -d'-' -f1 | cut -d'_' -f1 | sed 's/[^0-9.]//g')

    if [ "$clean_latest" != "$clean_installed" ] && [ -n "$clean_latest" ] && [ "$installed_version" != "$(msg status_unknown)" ] && [ "$installed_version" != "$(msg status_not_installed)" ]; then
      printf "\n$(msg leboot_update_available) $latest_version ($(msg status_installed): $installed_version).\n$(msg leboot_update_prompt) $(msg yes_no_default_y)"
      read -r update_choice
      if [ "$update_choice" != "n" ] && [ "$update_choice" != "N" ]; then
        flash_leboot
      fi
    else
      if [ "$is_startup" != "startup" ]; then
        echo "$(msg leboot_update_latest) ($installed_version)."
      fi
    fi
  else
    if [ "$is_startup" != "startup" ]; then
      echo "$(msg leboot_update_err)"
    fi
  fi
}

leboot_menu() {
  while true; do
    local mtd_fip=$(find_mtd_partition "fip")
    local mtd_fip_name=$(find_mtd_partition_name "fip")
    local installed_ver=$(get_installed_leboot_version)
    
    echo "=================================================="
    echo "  $(msg leboot_title)"
    echo "=================================================="
    echo "$(msg leboot_status)"
    echo "  $(msg leboot_partition) $mtd_fip_name ($mtd_fip)"
    echo "  $(msg leboot_version)   $installed_ver"
    echo "--------------------------------------------------"
    echo "$(msg main_choose)"
    echo "  [1] $(msg leboot_opt_flash)"
    echo "  [2] $(msg leboot_opt_backup)"
    echo "  [99] $(msg leboot_update_title)"
    echo "  [0] $(msg leboot_back)"
    echo "=================================================="
    printf "Ваш выбор / Your choice: "
    read -r choice
    case "$choice" in
      1) flash_leboot ;;
      2) backup_fip ;;
      99) check_leboot_updates ;;
      0) return ;;
      *) echo "$(msg invalid_input)" ;;
    esac
    printf "\n$(msg press_enter)"
    read -r _
  done
}


# --- ФУНКЦИИ ДЛЯ LEKIT UPDATE ---
check_lekit_updates() {
  local is_startup="$1"
  if [ "$is_startup" != "startup" ]; then
    echo -e "\n$(msg lekit_update_title)"
  fi
  TEMP_FILE="/tmp/lekit_new"

  if wget --no-check-certificate -qO "$TEMP_FILE" "https://raw.githubusercontent.com/Le-Maxime/LEKIT/main/lekit"; then
    new_version=$(grep "^LEKIT_VERSION=" "$TEMP_FILE" | cut -d'"' -f2)
    if [ -n "$new_version" ]; then
      if [ "$new_version" != "$LEKIT_VERSION" ]; then
        printf "\n$(msg lekit_update_available) $new_version ($(msg main_version)).\n$(msg lekit_update_prompt) $(msg yes_no_default_y)"
        read -r update_choice
        if [ "$update_choice" != "n" ] && [ "$update_choice" != "N" ]; then
          echo "$(msg lekit_updating)"
          mv "$TEMP_FILE" "$0"
          chmod +x "$0"
          if [ "$0" != "/usr/sbin/lekit" ] && [ -f "/usr/sbin/lekit" ]; then
            cp "$0" /usr/sbin/lekit
            chmod +x /usr/sbin/lekit
          fi
          echo "$(msg lekit_update_success)"
          exit 0
        fi
      else
        if [ "$is_startup" != "startup" ]; then
          echo "$(msg lekit_update_latest) ($LEKIT_VERSION)."
        fi
      fi
    else
      if [ "$is_startup" != "startup" ]; then
        echo "$(msg lekit_update_parse_err)"
      fi
    fi
    rm -f "$TEMP_FILE"
  else
    if [ "$is_startup" != "startup" ]; then
      echo "$(msg lekit_update_err)"
    fi
  fi
}


