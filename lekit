# --- ФУНКЦИИ ДЛЯ UFAN ---
get_installed_ufan_version() {
  if [ -f "$BIN" ]; then
    if [ -f "$UFAN_VER_FILE" ]; then
      cat "$UFAN_VER_FILE"
    else
      echo "2.0.2"
    fi
  else
    echo "$(msg status_not_installed)"
  fi
}

fetch_latest_ufan_version() {
  wget --no-check-certificate -qO- https://api.github.com/repos/andros-ua/ufan/releases/latest | sed -n 's/.*"tag_name":"\([^"]*\)".*/\1/p'
}

install_ufan() {
  echo -e "\n$(msg ufan_install_start)"
  echo "$(msg ufan_fetching_ver)"
  latest_ufan=$(fetch_latest_ufan_version)
  if [ -z "$latest_ufan" ]; then
    latest_ufan="$UFAN_VERSION"
  fi
  
  echo "$(msg ufan_installing_ver) $latest_ufan..."

  if [ -f "$BIN" ] || [ -f "$INIT" ]; then
    echo "$(msg ufan_stopping)"
    service ufan stop 2>/dev/null
  fi

  echo "$(msg ufan_downloading_bin)"
  if ! wget --no-check-certificate -qO "$BIN" "https://github.com/andros-ua/ufan/raw/refs/heads/main/usr/sbin/ufan"; then
    echo "$(msg ufan_download_err) $BIN."
    return 1
  fi
  chmod +x "$BIN"

  echo "$(msg ufan_downloading_init)"
  if ! wget --no-check-certificate -qO "$INIT" "https://github.com/andros-ua/ufan/raw/refs/heads/main/etc/init.d/ufan"; then
    echo "$(msg ufan_download_err) $INIT."
    return 1
  fi
  chmod +x "$INIT"

  echo "$latest_ufan" > "$UFAN_VER_FILE"

  echo "$(msg ufan_enabling)"
  service ufan enable 2>/dev/null || /etc/init.d/ufan enable 2>/dev/null
  service ufan start 2>/dev/null || /etc/init.d/ufan start 2>/dev/null

  echo "$(msg ufan_install_success)"
  ask_sysupgrade
}

install_fan_monitoring() {
  echo -e "\n$(msg ufan_mon_install_start)"
  echo "$(msg ufan_mon_deps)"
  if command -v apk >/dev/null; then
    apk update 2>/dev/null
    apk add luci-app-statistics collectd-mod-exec
  elif command -v opkg >/dev/null; then
    opkg update
    opkg install luci-app-statistics collectd-mod-exec
  fi

  wget_ok=1
  echo "$(msg ufan_mon_downloading_script)"
  mkdir -p "$(dirname "$FAN_SCRIPT")"
  if ! wget --no-check-certificate -qO "$FAN_SCRIPT" "https://github.com/andros-ua/ufan/raw/refs/heads/main/usr/share/collectd/pwmfan.sh"; then
    echo "$(msg ufan_mon_download_script_err)"
    wget_ok=0
  else
    chmod +x "$FAN_SCRIPT"
  fi

  if [ "$wget_ok" -eq 1 ]; then
    echo "$(msg ufan_mon_downloading_js)"
    mkdir -p "$(dirname "$FAN_LUCI_JS")"
    if ! wget --no-check-certificate -qO "$FAN_LUCI_JS" "https://github.com/andros-ua/ufan/raw/refs/heads/main/www/luci-static/resources/statistics/rrdtool/definitions/exec.js"; then
      echo "$(msg ufan_mon_download_js_err)"
      wget_ok=0
      rm -f "$FAN_SCRIPT"
    fi
  fi

  if [ "$wget_ok" -eq 1 ]; then
    if [ -f "$LUCI_STATS_CONF" ]; then
      echo "$(msg ufan_mon_configuring_collectd)"
      uci set luci_statistics.collectd_exec=statistics
      uci set luci_statistics.collectd_exec.enable='1'
      uci set luci_statistics.pwmfan=collectd_exec_input
      uci set luci_statistics.pwmfan.cmdline="/usr/share/collectd/pwmfan.sh"
      uci set luci_statistics.pwmfan.cmduser="nobody"
      uci set luci_statistics.pwmfan.cmdgroup="nogroup"
      uci commit luci_statistics
      echo "$(msg ufan_mon_restarting_stats)"
      /etc/init.d/luci_statistics restart 2>/dev/null
    elif [ -f "$COLLECTD_CONF" ]; then
      if ! grep -qF "$FAN_SCRIPT" "$COLLECTD_CONF"; then
        echo "$(msg ufan_mon_configuring_collectd)"
        if ! grep -q "^[ 	]*LoadPlugin[ 	][ 	]*exec" "$COLLECTD_CONF"; then
          echo -e "\nLoadPlugin exec" >> "$COLLECTD_CONF"
        fi
        cat >> "$COLLECTD_CONF" << 'EOF'

#BEGIN_PWMFAN
<Plugin exec>
        Exec "nobody:nogroup" "/usr/share/collectd/pwmfan.sh"
</Plugin>
#END_PWMFAN
EOF
      fi
      echo "$(msg ufan_mon_restarting_collectd)"
      service collectd restart 2>/dev/null || /etc/init.d/collectd restart 2>/dev/null
    else
      echo "$(msg ufan_mon_collectd_not_found)"
    fi
    echo "$(msg ufan_mon_success)"
    ask_sysupgrade
  else
    return 1
  fi
}

uninstall_ufan() {
  echo -e "\n$(msg ufan_uninstall_start)"
  printf "$(msg ufan_uninstall_confirm) $(msg yes_no_default_n)"
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "$(msg ufan_uninstall_cancelled)"
    return 0
  fi

  echo "$(msg ufan_uninstall_stopping)"
  service ufan stop 2>/dev/null
  service ufan disable 2>/dev/null
  rm -f "$BIN" "$INIT" "$UFAN_VER_FILE"

  echo "$(msg ufan_uninstall_files)"
  rm -f "$FAN_SCRIPT" "$FAN_LUCI_JS"

  if [ -f "$LUCI_STATS_CONF" ]; then
    echo "$(msg ufan_uninstall_uci)"
    uci delete luci_statistics.pwmfan 2>/dev/null
    uci commit luci_statistics 2>/dev/null
    /etc/init.d/luci_statistics restart 2>/dev/null
  fi

  if [ -f "$COLLECTD_CONF" ]; then
    echo "$(msg ufan_uninstall_collectd)"
    sed -i '/#BEGIN_PWMFAN/,/#END_PWMFAN/d' "$COLLECTD_CONF" 2>/dev/null
    sed -i '\#/usr/share/collectd/pwmfan.sh#d' "$COLLECTD_CONF" 2>/dev/null
    service collectd restart 2>/dev/null || /etc/init.d/collectd restart 2>/dev/null
  fi

  echo "$(msg ufan_uninstall_sysupgrade)"
  sed -i '\#/usr/sbin/ufan#d' "$CONF" 2>/dev/null
  sed -i '\#/etc/init.d/ufan#d' "$CONF" 2>/dev/null
  sed -i '\#/etc/ufan.version#d' "$CONF" 2>/dev/null
  sed -i '\#/etc/collectd.conf#d' "$CONF" 2>/dev/null
  sed -i '\#/usr/share/collectd/pwmfan.sh#d' "$CONF" 2>/dev/null
  sed -i '\#/www/luci-static/resources/statistics/rrdtool/definitions/exec.js#d' "$CONF" 2>/dev/null

  echo "$(msg ufan_uninstall_success)"
}

check_ufan_updates() {
  local is_startup="$1"
  if [ "$is_startup" != "startup" ]; then
    echo "$(msg ufan_update_title)"
  fi

  if [ ! -f "$BIN" ]; then
    if [ "$is_startup" != "startup" ]; then
