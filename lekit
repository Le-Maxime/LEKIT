# --- АВТОМАТИЧЕСКАЯ УСТАНОВКА В СИСТЕМУ ---
install_to_system() {
  if [ -w "/usr/sbin" ]; then
    if [ -f "$0" ] && [ "$0" != "/usr/sbin/lekit" ]; then
      cp "$0" /usr/sbin/lekit 2>/dev/null
      chmod +x /usr/sbin/lekit 2>/dev/null
      echo "=================================================="
      if [ "$LEKIT_LANG" = "en" ]; then
        echo "  [LEKIT] Script copied to /usr/sbin/lekit"
        echo "  Now you can run it using 'lekit' command"
      else
        echo "  [LEKIT] Скрипт скопирован в /usr/sbin/lekit"
        echo "  Теперь вы можете запускать его командой 'lekit'"
      fi
      echo "=================================================="
      echo ""
    elif [ "$0" = "sh" ] || [ "$0" = "-sh" ] || [ "$0" = "bash" ] || [ ! -f "$0" ]; then
      echo "=================================================="
      if [ "$LEKIT_LANG" = "en" ]; then
        echo "  [LEKIT] Downloading and installing to /usr/sbin/lekit..."
      else
        echo "  [LEKIT] Скачивание и установка в /usr/sbin/lekit..."
      fi
      wget --no-check-certificate -qO /usr/sbin/lekit "https://raw.githubusercontent.com/Le-Maxime/LEKIT/main/lekit" 2>/dev/null
      chmod +x /usr/sbin/lekit 2>/dev/null
      if [ "$LEKIT_LANG" = "en" ]; then
        echo "  Installation completed. Command to run: lekit"
      else
        echo "  Установка завершена. Команда для запуска: lekit"
      fi
      echo "=================================================="
      echo ""
    fi
    
    if [ -f "/usr/sbin/lekit" ] && [ -f "$CONF" ]; then
      grep -qF "/usr/sbin/lekit" "$CONF" || echo "/usr/sbin/lekit" >> "$CONF" 2>/dev/null
      grep -qF "$LANG_FILE" "$CONF" || echo "$LANG_FILE" >> "$CONF" 2>/dev/null
    fi
  fi
}

if [ "$0" != "/usr/sbin/lekit" ]; then
  install_to_system
fi


# --- ФУНКЦИИ ДЛЯ PROTON2025 ---
get_installed_theme_version() {
  if [ -d "$THEME_DIR" ]; then
    if command -v apk >/dev/null; then
      apk info luci-theme-proton2025 2>/dev/null | head -n 1 | sed 's/luci-theme-proton2025-//' | cut -d' ' -f1
    elif command -v opkg >/dev/null; then
      opkg status luci-theme-proton2025 2>/dev/null | grep -i "^Version:" | cut -d' ' -f2
    else
      msg "status_unknown"
    fi
  else
    msg "status_not_installed"
  fi
}

install_theme() {
  echo "$(msg theme_install_start)"
  echo "$(msg theme_fetching_ver)"

  release_json=$(wget --no-check-certificate -qO- https://api.github.com/repos/ChesterGoodiny/luci-theme-proton2025/releases/latest)
  theme_latest_version=$(echo "$release_json" | tr ',' '\n' | grep "^\"tag_name\":" | cut -d'"' -f4)

  if [ -z "$theme_latest_version" ]; then
    echo "$(msg theme_ver_err)"
    return 1
  fi

  echo "$(msg theme_latest_ver) $theme_latest_version"

  if command -v apk >/dev/null; then
    apk_url=$(echo "$release_json" | tr ',' '\n' | grep "browser_download_url" | grep -i "\.apk" | cut -d'"' -f4)
    if [ -z "$apk_url" ]; then
      echo "$(msg theme_apk_err)"
      return 1
    fi
    echo "$(msg theme_downloading_apk)"
    TEMP_APK="/tmp/luci-theme-proton2025.apk"
    if ! wget --no-check-certificate -qO "$TEMP_APK" "$apk_url"; then
      echo "$(msg theme_download_apk_err)"
      return 1
    fi
    echo "$(msg theme_installing_apk)"
    if apk add --allow-untrusted "$TEMP_APK"; then
      echo "$(msg theme_success)"
      rm -f "$TEMP_APK"
      clear_luci_cache
    else
      echo "$(msg theme_install_pkg_err)"
      rm -f "$TEMP_APK"
      return 1
    fi

  elif command -v opkg >/dev/null; then
    ipk_url=$(echo "$release_json" | tr ',' '\n' | grep "browser_download_url" | grep -i "\.ipk" | cut -d'"' -f4)
    if [ -z "$ipk_url" ]; then
      echo "$(msg theme_ipk_err)"
      return 1
    fi
    echo "$(msg theme_downloading_ipk)"
    TEMP_IPK="/tmp/luci-theme-proton2025.ipk"
    if ! wget --no-check-certificate -qO "$TEMP_IPK" "$ipk_url"; then
      echo "$(msg theme_download_ipk_err)"
      return 1
    fi
    echo "$(msg theme_installing_ipk)"
    if opkg install "$TEMP_IPK"; then
      echo "$(msg theme_success)"
      rm -f "$TEMP_IPK"
      clear_luci_cache
    else
      echo "$(msg theme_install_pkg_err)"
      rm -f "$TEMP_IPK"
      return 1
    fi
  else
    echo "$(msg theme_no_pkg_manager)"
    return 1
  fi
}

uninstall_theme() {
  echo "$(msg theme_uninstall_start)"
  if [ ! -d "$THEME_DIR" ]; then
    echo "$(msg proton_installed_ver) $(msg status_not_installed)"
    return 0
  fi

  printf "$(msg theme_uninstall_confirm) $(msg yes_no_default_n)"
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    echo "$(msg theme_uninstall_cancelled)"
    return 0
  fi

  echo "$(msg theme_uninstall_files)"
  if command -v apk >/dev/null; then
    apk del luci-theme-proton2025
  elif command -v opkg >/dev/null; then
    opkg remove luci-theme-proton2025
  else
    rm -rf "$THEME_DIR"
  fi

  rm -f /etc/config/proton2025

  if [ "$(uci get luci.main.mediaurlbase 2>/dev/null)" = "/luci-static/proton2025" ]; then
    echo "$(msg theme_uninstall_reset)"
    uci set luci.main.mediaurlbase="/luci-static/bootstrap" 2>/dev/null
    uci commit luci 2>/dev/null
  fi

  clear_luci_cache
  echo "$(msg theme_uninstall_success)"
}

check_theme_updates() {
  local is_startup="$1"
  if [ "$is_startup" != "startup" ]; then
    echo "$(msg theme_update_title)"
  fi

  if [ ! -d "$THEME_DIR" ]; then
    if [ "$is_startup" != "startup" ]; then
      echo "$(msg proton_installed_ver) $(msg status_not_installed)"
    fi
    return 0
  fi

  if [ "$is_startup" != "startup" ]; then
    echo "$(msg theme_update_fetching)"
  fi

  theme_latest_version=$(wget --no-check-certificate -qO- https://api.github.com/repos/ChesterGoodiny/luci-theme-proton2025/releases/latest | tr ',' '\n' | grep "^\"tag_name\":" | cut -d'"' -f4)

  if [ -n "$theme_latest_version" ]; then
    theme_installed_version=$(get_installed_theme_version)
    theme_clean_latest=$(echo "$theme_latest_version" | cut -d'-' -f1 | cut -d'_' -f1 | sed 's/[^0-9.]//g')
    theme_clean_installed=$(echo "$theme_installed_version" | cut -d'-' -f1 | cut -d'_' -f1 | sed 's/[^0-9.]//g')

    if [ "$theme_clean_latest" != "$theme_clean_installed" ] && [ -n "$theme_clean_latest" ]; then
      printf "\n$(msg theme_update_available) $theme_latest_version ($(msg status_installed): $theme_installed_version).\n$(msg theme_update_prompt) $(msg yes_no_default_y)"
